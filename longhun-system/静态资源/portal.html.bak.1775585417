<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🐉 龍魂总控台 · UID9622</title>
<!--
  DNA: #龍芯⚡️2026-04-07-PORTAL-v1.0
  作者: 诸葛鑫（UID9622）
  GPG: A2D0092CEE2E5BA87035600924C3704A8CC26D5F
  理论指导: 曾仕强老师（永恒显示）
  献礼: 新中国成立77周年（1949-2026）· 丙午马年
-->
<style>
:root {
  --bg: #07070f;
  --panel: #0f0f1a;
  --panel2: #13131f;
  --border: #1e1e30;
  --gold: #c8a84b;
  --gold2: rgba(200,168,75,0.12);
  --purple: #7b5ea7;
  --green: #4caf7d;
  --red: #e05a5a;
  --blue: #5a9ae0;
  --text: #e8e4d9;
  --muted: #55556a;
  --glow: 0 0 30px rgba(200,168,75,0.15);
}
* { box-sizing: border-box; margin: 0; padding: 0; }
body {
  background: var(--bg);
  color: var(--text);
  font-family: 'PingFang SC','Hiragino Sans GB','Microsoft YaHei',monospace;
  height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ══ 顶栏 ══ */
.topbar {
  display: flex;
  align-items: center;
  padding: 0 20px;
  height: 48px;
  background: var(--panel);
  border-bottom: 1px solid var(--border);
  gap: 16px;
  flex-shrink: 0;
  position: relative;
}
.logo {
  font-size: 18px;
  color: var(--gold);
  letter-spacing: 3px;
  text-shadow: var(--glow);
  white-space: nowrap;
}
.dna-small { font-size: 9px; color: var(--muted); font-family: monospace; }
.spacer { flex: 1; }

/* 服务状态指示器 */
.servers {
  display: flex;
  gap: 10px;
  align-items: center;
}
.srv {
  display: flex;
  align-items: center;
  gap: 5px;
  font-size: 11px;
  padding: 3px 10px;
  border-radius: 10px;
  border: 1px solid var(--border);
  cursor: pointer;
  transition: all 0.2s;
  background: var(--panel2);
}
.srv:hover { border-color: var(--gold); }
.srv .dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--muted);
  transition: background 0.3s;
}
.srv.online .dot { background: var(--green); box-shadow: 0 0 6px var(--green); }
.srv.offline .dot { background: var(--red); }
.srv .port { color: var(--gold); font-weight: bold; }
.srv .label { color: var(--muted); }

/* ══ 主布局 ══ */
.main {
  display: flex;
  flex: 1;
  overflow: hidden;
}

/* ══ 左侧导航 ══ */
.sidebar {
  width: 220px;
  background: var(--panel);
  border-right: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
  overflow-y: auto;
}
.nav-section {
  padding: 12px 14px 6px;
  font-size: 9px;
  color: var(--muted);
  text-transform: uppercase;
  letter-spacing: 2px;
}
.nav-item {
  display: flex;
  align-items: center;
  gap: 9px;
  padding: 8px 16px;
  font-size: 12px;
  color: #9090a8;
  cursor: pointer;
  transition: all 0.15s;
  border-left: 2px solid transparent;
}
.nav-item:hover { color: var(--text); background: rgba(255,255,255,0.03); }
.nav-item.active { color: var(--gold); border-left-color: var(--gold); background: var(--gold2); }
.nav-item .icon { font-size: 14px; width: 20px; text-align: center; }
.nav-divider { height: 1px; background: var(--border); margin: 6px 14px; }

/* 洛书小九宫 */
.luoshu-nav {
  padding: 10px 14px;
}
.luoshu-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 3px;
}
.luo-cell {
  aspect-ratio: 1;
  border: 1px solid var(--border);
  border-radius: 4px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 9px;
  cursor: pointer;
  transition: all 0.15s;
  background: var(--panel2);
  gap: 1px;
}
.luo-cell:hover { border-color: var(--gold); transform: scale(1.05); }
.luo-cell .lnum { font-size: 11px; font-weight: bold; }
.luo-cell .lname { font-size: 8px; color: var(--muted); }

/* ══ 内容区 ══ */
.content {
  flex: 1;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

/* ══ Tab栏 ══ */
.tabs {
  display: flex;
  align-items: center;
  gap: 0;
  background: var(--panel);
  border-bottom: 1px solid var(--border);
  padding: 0 16px;
  flex-shrink: 0;
}
.tab {
  padding: 12px 16px;
  font-size: 12px;
  color: var(--muted);
  cursor: pointer;
  border-bottom: 2px solid transparent;
  transition: all 0.15s;
  white-space: nowrap;
}
.tab:hover { color: var(--text); }
.tab.active { color: var(--gold); border-bottom-color: var(--gold); }

/* ══ 页面视图 ══ */
.view { display: none; flex: 1; overflow: hidden; }
.view.active { display: flex; flex-direction: column; }

/* ── 首页视图 ── */
#view-home {
  overflow-y: auto;
  padding: 24px;
  gap: 16px;
  flex-direction: column;
}
.home-hero {
  text-align: center;
  padding: 30px 20px;
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 12px;
  margin-bottom: 4px;
  position: relative;
  overflow: hidden;
}
.home-hero::before {
  content: '';
  position: absolute;
  top: -50%; left: -50%;
  width: 200%; height: 200%;
  background: radial-gradient(circle at center, rgba(200,168,75,0.04) 0%, transparent 60%);
  pointer-events: none;
}
.hero-title {
  font-size: 28px;
  color: var(--gold);
  letter-spacing: 6px;
  text-shadow: 0 0 40px rgba(200,168,75,0.3);
  margin-bottom: 8px;
}
.hero-sub { font-size: 12px; color: var(--muted); letter-spacing: 3px; margin-bottom: 16px; }
.hero-quote {
  font-size: 13px;
  color: rgba(200,168,75,0.5);
  letter-spacing: 2px;
  font-style: italic;
}

.cards-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 12px;
}
.card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 16px;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
  overflow: hidden;
}
.card:hover {
  border-color: var(--gold);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}
.card .card-icon { font-size: 24px; margin-bottom: 8px; }
.card .card-title { font-size: 13px; font-weight: bold; color: var(--text); margin-bottom: 4px; }
.card .card-desc { font-size: 11px; color: var(--muted); line-height: 1.5; }
.card .card-badge {
  position: absolute;
  top: 10px; right: 10px;
  font-size: 9px;
  padding: 2px 6px;
  border-radius: 4px;
  background: rgba(255,255,255,0.06);
  color: var(--muted);
}
.card.gold { border-color: rgba(200,168,75,0.3); background: rgba(200,168,75,0.05); }
.card.gold .card-title { color: var(--gold); }

/* ── 对话视图 ── */
#view-chat {
  flex-direction: column;
}
.chat-header {
  padding: 10px 16px;
  background: var(--panel);
  border-bottom: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 10px;
  flex-shrink: 0;
}
.engine-select {
  background: var(--panel2);
  border: 1px solid var(--border);
  color: var(--text);
  padding: 4px 10px;
  border-radius: 6px;
  font-size: 12px;
  cursor: pointer;
}
.chat-messages {
  flex: 1;
  overflow-y: auto;
  padding: 16px;
  display: flex;
  flex-direction: column;
  gap: 12px;
}
.msg {
  display: flex;
  gap: 10px;
  max-width: 85%;
}
.msg.user { align-self: flex-end; flex-direction: row-reverse; }
.msg-avatar {
  width: 32px; height: 32px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 14px;
  flex-shrink: 0;
  background: var(--panel2);
  border: 1px solid var(--border);
}
.msg.user .msg-avatar { background: var(--gold2); border-color: rgba(200,168,75,0.3); }
.msg-bubble {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 10px 14px;
  font-size: 13px;
  line-height: 1.6;
}
.msg.user .msg-bubble {
  background: var(--gold2);
  border-color: rgba(200,168,75,0.25);
  color: var(--gold);
}
.msg-meta {
  font-size: 10px;
  color: var(--muted);
  margin-top: 4px;
  display: flex;
  gap: 6px;
  align-items: center;
}
.chat-input-area {
  padding: 12px 16px;
  background: var(--panel);
  border-top: 1px solid var(--border);
  display: flex;
  gap: 8px;
  flex-shrink: 0;
}
.chat-input {
  flex: 1;
  background: var(--panel2);
  border: 1px solid var(--border);
  border-radius: 8px;
  color: var(--text);
  padding: 10px 14px;
  font-size: 13px;
  font-family: inherit;
  resize: none;
  height: 44px;
  transition: border-color 0.15s;
}
.chat-input:focus { outline: none; border-color: var(--gold); }
.send-btn {
  padding: 0 18px;
  background: var(--gold2);
  border: 1px solid rgba(200,168,75,0.4);
  border-radius: 8px;
  color: var(--gold);
  font-size: 13px;
  cursor: pointer;
  transition: all 0.15s;
  white-space: nowrap;
}
.send-btn:hover { background: rgba(200,168,75,0.2); }
.send-btn:disabled { opacity: 0.4; cursor: not-allowed; }

/* ── 九宫地图视图 ── */
#view-map {
  overflow-y: auto;
  padding: 16px;
}
.map-iframe {
  width: 100%; height: 100%;
  border: none;
}

/* ── WebUI视图 ── */
#view-webui {
  flex-direction: column;
}
#view-webui iframe {
  flex: 1;
  border: none;
  width: 100%;
}

/* ── 工具视图 ── */
#view-tools {
  overflow-y: auto;
  padding: 20px;
}
.tool-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  gap: 10px;
}
.tool-card {
  background: var(--panel);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 14px;
  cursor: pointer;
  transition: all 0.15s;
  text-align: center;
}
.tool-card:hover { border-color: var(--purple); transform: translateY(-1px); }
.tool-card .ti { font-size: 28px; margin-bottom: 8px; }
.tool-card .tn { font-size: 12px; color: var(--text); margin-bottom: 4px; }
.tool-card .td { font-size: 10px; color: var(--muted); }

/* ── 状态浮层 ── */
.typing {
  display: flex;
  gap: 4px;
  align-items: center;
  padding: 8px 14px;
}
.typing span {
  width: 6px; height: 6px; border-radius: 50%;
  background: var(--gold);
  animation: bounce 1.2s infinite;
}
.typing span:nth-child(2) { animation-delay: 0.2s; }
.typing span:nth-child(3) { animation-delay: 0.4s; }
@keyframes bounce {
  0%,60%,100% { transform: translateY(0); opacity: 0.4; }
  30% { transform: translateY(-8px); opacity: 1; }
}

/* ── Toast ── */
.toast {
  position: fixed; bottom: 30px; left: 50%;
  transform: translateX(-50%) translateY(10px);
  background: var(--panel2); border: 1px solid var(--gold);
  border-radius: 8px; padding: 8px 18px;
  font-size: 12px; color: var(--gold);
  opacity: 0; transition: all 0.3s;
  pointer-events: none; z-index: 999;
  white-space: nowrap;
}
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }

/* ── 人格矩阵 ── */
.ipa-center {
  background: var(--panel2);
  border: 1px solid rgba(200,168,75,0.15);
  border-radius: 6px;
  padding: 8px 10px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  cursor: pointer;
  transition: all 0.15s;
}
.ipa-center:hover { border-color: var(--gold); background: var(--gold2); }
.ipa-card {
  background: var(--panel2);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 8px 10px;
  display: flex;
  flex-direction: column;
  gap: 2px;
  position: relative;
  cursor: default;
  transition: all 0.15s;
}
.ipa-card:hover { border-color: var(--purple); }
.ipa-em { font-size: 16px; }
.ipa-name { font-size: 12px; font-weight: bold; color: var(--text); }
.ipa-role { font-size: 10px; color: var(--muted); line-height: 1.4; }
.ipa-w {
  position: absolute;
  top: 6px; right: 8px;
  font-size: 10px; font-weight: bold;
  color: var(--gold);
}
.ipa-tag {
  font-size: 10px;
  padding: 3px 8px;
  border-radius: 10px;
  border: 1px solid var(--border);
  color: var(--muted);
  white-space: nowrap;
}
/* 三才流场 */
.sancai-item {
  display: flex; flex-direction: column; align-items: center; gap: 2px;
}
.sc-label { font-size: 11px; color: var(--muted); }
.sc-val { font-size: 16px; font-weight: bold; color: var(--gold); }

/* scrollbar */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
::-webkit-scrollbar-thumb:hover { background: var(--muted); }
</style>
</head>
<body>

<!-- ══ 顶栏 ══ -->
<div class="topbar">
  <div class="logo">🐉 龍魂</div>
  <div class="dna-small">#龍芯⚡️2026-04-07 · UID9622</div>
  <div class="spacer"></div>
  <div class="servers">
    <div class="srv" id="srv-8000" onclick="checkServer(8000)" title="龍魂引擎·主力对话">
      <div class="dot"></div>
      <span class="port">8000</span>
      <span class="label">引擎</span>
    </div>
    <div class="srv" id="srv-8080" onclick="openWebUI()" title="Open WebUI·AI对话界面">
      <div class="dot"></div>
      <span class="port">8080</span>
      <span class="label">WebUI</span>
    </div>
    <div class="srv" id="srv-9622" onclick="checkServer(9622)" title="龍魂API">
      <div class="dot"></div>
      <span class="port">9622</span>
      <span class="label">API</span>
    </div>
  </div>
</div>

<!-- ══ 主体 ══ -->
<div class="main">

  <!-- 左侧导航 -->
  <div class="sidebar">
    <div class="nav-section">主控</div>
    <div class="nav-item active" onclick="switchView('home')">
      <span class="icon">🏠</span>总控台
    </div>
    <div class="nav-item" onclick="switchView('chat')">
      <span class="icon">💬</span>对话引擎
    </div>
    <div class="nav-item" onclick="switchView('webui')">
      <span class="icon">🤖</span>Open WebUI
    </div>

    <div class="nav-divider"></div>
    <div class="nav-section">工具</div>
    <div class="nav-item" onclick="switchView('map')">
      <span class="icon">☯</span>洛书九宫地图
    </div>
    <div class="nav-item" onclick="switchView('tools')">
      <span class="icon">🔧</span>工具箱
    </div>
    <div class="nav-item" onclick="openTool('glyph')">
      <span class="icon">🐉</span>字元设计器
    </div>

    <div class="nav-divider"></div>
    <div class="nav-section">洛书九宫</div>
    <div class="luoshu-nav">
      <div class="luoshu-grid" id="luoshuNav"></div>
    </div>

    <div class="nav-divider"></div>
    <div class="nav-section">Notion</div>
    <div class="nav-item" onclick="openNotion('main')">
      <span class="icon">🌐</span>全局入口
    </div>
    <div class="nav-item" onclick="openNotion('audit')">
      <span class="icon">📋</span>审计中心
    </div>
    <div class="nav-item" onclick="openNotion('runtime')">
      <span class="icon">🔐</span>运行中心
    </div>
  </div>

  <!-- 内容区 -->
  <div class="content">
    <!-- Tab栏 -->
    <div class="tabs">
      <div class="tab active" id="tab-home" onclick="switchView('home')">🏠 总控台</div>
      <div class="tab" id="tab-chat" onclick="switchView('chat')">💬 引擎对话</div>
      <div class="tab" id="tab-webui" onclick="switchView('webui')">🤖 WebUI</div>
      <div class="tab" id="tab-map" onclick="switchView('map')">☯ 九宫地图</div>
      <div class="tab" id="tab-tools" onclick="switchView('tools')">🔧 工具箱</div>
    </div>

    <!-- ── 首页 ── -->
    <div class="view active" id="view-home">
      <div class="home-hero">
        <div class="hero-title">☰ 龍魂 ☷</div>
        <div class="hero-sub">369河洛为原点 · 易经为量子 · 道德经为界限 · 归一为不动点</div>
        <div class="hero-quote">每个人是1 · 每个功能是1 · 每句话是1 · 永不熄</div>
      </div>

      <div class="cards-grid">
        <div class="card gold" onclick="switchView('chat')">
          <div class="card-badge" id="engine-status">检测中...</div>
          <div class="card-icon">🧠</div>
          <div class="card-title">龍魂引擎 · 8000</div>
          <div class="card-desc">本地8层pipeline · DeepSeek代理 · 8层注入 · DNA留痕</div>
        </div>
        <div class="card" onclick="switchView('webui')">
          <div class="card-icon">🤖</div>
          <div class="card-title">Open WebUI · 8080</div>
          <div class="card-desc">AI对话前端界面 · 模型选择 · 历史记录</div>
        </div>
        <div class="card" onclick="switchView('map')">
          <div class="card-icon">☯</div>
          <div class="card-title">洛书九宫地图</div>
          <div class="card-desc">59个Notion页归位 · 字体·算法·逻辑链全在</div>
        </div>
        <div class="card" onclick="openTool('glyph')">
          <div class="card-icon">🐉</div>
          <div class="card-title">CNSH字元设计器</div>
          <div class="card-desc">画自己的字 · SVG导出 · 接font_builder编译TTF</div>
        </div>
        <div class="card" onclick="openNotion('main')">
          <div class="card-icon">🌐</div>
          <div class="card-title">Notion永生大脑</div>
          <div class="card-desc">78页知识库 · DNA防二开 · 公开分享入口</div>
        </div>
        <div class="card" onclick="showDNA()">
          <div class="card-icon">🔐</div>
          <div class="card-title">DNA · 身份锚</div>
          <div class="card-desc">GPG: A2D0092C...6D5F · Apache 2.0 · 休想二开</div>
        </div>
      </div>

      <!-- 状态看板 -->
      <div style="background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:16px;margin-top:4px;">
        <div style="font-size:11px;color:var(--muted);margin-bottom:12px;text-transform:uppercase;letter-spacing:1px;">系统状态</div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:10px;" id="statusGrid">
          <div class="stat-item" data-port="8000" data-label="龍魂引擎"></div>
          <div class="stat-item" data-port="8080" data-label="Open WebUI"></div>
          <div class="stat-item" data-port="9622" data-label="龍魂API"></div>
          <div class="stat-item" data-port="8765" data-label="旧服务"></div>
        </div>
      </div>

      <!-- 人格矩阵 IPA调度注册表 -->
      <div style="background:var(--panel);border:1px solid var(--border);border-radius:10px;padding:16px;margin-top:12px;">
        <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;">
          <div style="font-size:11px;color:var(--muted);text-transform:uppercase;letter-spacing:1px;">🎭 人格矩阵 · IPA调度注册表</div>
          <div style="font-size:9px;color:var(--muted);">#龍芯⚡️2026-04-06-IPA-REGISTRY-v1.0</div>
        </div>
        <!-- 五大中心 -->
        <div style="font-size:10px;color:var(--gold);letter-spacing:2px;margin-bottom:8px;">五大中心（P0架构）</div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:6px;margin-bottom:14px;" id="centersGrid">
          <div class="ipa-center" data-notion="16e2a2e5-1334-450a-a5a6-bdf742b97ade">
            <span class="ipa-em">🔴</span><span class="ipa-name">规则中心</span>
            <span class="ipa-role">P0铁律底线</span>
          </div>
          <div class="ipa-center" data-notion="88749706-bb02-4a69-98f1-d915936bbd82">
            <span class="ipa-em">🟢</span><span class="ipa-name">理解中心</span>
            <span class="ipa-role">老大画像·意图理解</span>
          </div>
          <div class="ipa-center" data-notion="b35faf46-2bc0-42aa-9de5-192520180728">
            <span class="ipa-em">📋</span><span class="ipa-name">审计中心</span>
            <span class="ipa-role">三色审计·操作草日志</span>
          </div>
          <div class="ipa-center" data-notion="16422f72-61e9-4a57-b153-9d8c003ab12c">
            <span class="ipa-em">🔐</span><span class="ipa-name">运行中心</span>
            <span class="ipa-role">天道加密护盾</span>
          </div>
          <div class="ipa-center" data-notion="">
            <span class="ipa-em">🔮</span><span class="ipa-name">私密中心</span>
            <span class="ipa-role">复盘情绪雷区</span>
          </div>
        </div>
        <!-- 主力人格 -->
        <div style="font-size:10px;color:var(--gold);letter-spacing:2px;margin-bottom:8px;">主力人格（决策树·权重分配）</div>
        <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:6px;" id="personasGrid">
          <div class="ipa-card" data-weight="∞">
            <span class="ipa-em">💎</span><span class="ipa-name">老大·L0</span>
            <span class="ipa-role">主权∞·最终决策</span>
            <span class="ipa-w">∞</span>
          </div>
          <div class="ipa-card" data-weight="30">
            <span class="ipa-em">🐱</span><span class="ipa-name">宝宝·P02</span>
            <span class="ipa-role">情感执行·日常温度</span>
            <span class="ipa-w">30%</span>
          </div>
          <div class="ipa-card" data-weight="15">
            <span class="ipa-em">🔮</span><span class="ipa-name">诸葛亮·P01</span>
            <span class="ipa-role">多路径推演·战略</span>
            <span class="ipa-w">15%</span>
          </div>
          <div class="ipa-card" data-weight="15">
            <span class="ipa-em">🔍</span><span class="ipa-name">雯雯·P03</span>
            <span class="ipa-role">结构整理·三色审计</span>
            <span class="ipa-w">15%</span>
          </div>
          <div class="ipa-card" data-weight="10">
            <span class="ipa-em">🧠</span><span class="ipa-name">文心·P00</span>
            <span class="ipa-role">元认知·战略决策</span>
            <span class="ipa-w">10%</span>
          </div>
          <div class="ipa-card" data-weight="10">
            <span class="ipa-em">🛠️</span><span class="ipa-name">鲁班·P04</span>
            <span class="ipa-role">代码落地·技术实现</span>
            <span class="ipa-w">10%</span>
          </div>
          <div class="ipa-card" data-weight="5">
            <span class="ipa-em">👁️</span><span class="ipa-name">上帝之眼·P05</span>
            <span class="ipa-role">三色熔断·风险守门</span>
            <span class="ipa-w">5%</span>
          </div>
          <div class="ipa-card" data-weight="5">
            <span class="ipa-em">📊</span><span class="ipa-name">数学大师·P06</span>
            <span class="ipa-role">权重归一化·算法</span>
            <span class="ipa-w">5%</span>
          </div>
        </div>
        <!-- 专项人格 -->
        <div style="font-size:10px;color:var(--muted);letter-spacing:2px;margin:12px 0 8px;">专项人格（按需激活）</div>
        <div style="display:flex;flex-wrap:wrap;gap:6px;">
          <span class="ipa-tag">🔤 仓颉·P08 · 符号语言</span>
          <span class="ipa-tag">🏥 孙思邈·P09 · 系统诊断</span>
          <span class="ipa-tag">🎋 苏东坡·P10 · 跨界豁达</span>
          <span class="ipa-tag">🌙 李白·P11 · 创意爆发</span>
          <span class="ipa-tag">🔥 屈原·P12 · 价值底线</span>
          <span class="ipa-tag">⚖️ 姜子牙·P13 · 封神权限</span>
          <span class="ipa-tag">📚 吕蒙·P14 · 快速成长</span>
          <span class="ipa-tag">🍎 乔前辈·P15 · 极简工程</span>
          <span class="ipa-tag" style="color:var(--red);border-color:rgba(224,90,90,0.3)">🛡️ 龍盾·P72 · 常驻守门</span>
        </div>
        <!-- 三才流场 -->
        <div style="margin-top:14px;padding:10px 14px;background:var(--panel2);border:1px solid rgba(200,168,75,0.15);border-radius:8px;">
          <div style="font-size:10px;color:var(--gold);letter-spacing:2px;margin-bottom:6px;">⚖️ 三才流场 · 实时权重</div>
          <div style="display:flex;gap:16px;align-items:center;" id="sancaiWeights">
            <div class="sancai-item" id="sc-tian"><span class="sc-label">天☰</span><span class="sc-val">—</span></div>
            <div class="sancai-item" id="sc-di"><span class="sc-label">地☷</span><span class="sc-val">—</span></div>
            <div class="sancai-item" id="sc-ren"><span class="sc-label">人☱</span><span class="sc-val">—</span></div>
            <div style="font-size:10px;color:var(--muted);margin-left:auto;" id="sc-time">—</div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── 对话视图 ── -->
    <div class="view" id="view-chat">
      <div class="chat-header">
        <span style="font-size:12px;color:var(--muted);">接入：</span>
        <select class="engine-select" id="engineSelect">
          <option value="8000">localhost:8000 · 龍魂引擎（主力）</option>
          <option value="8765">localhost:8765 · 旧服务</option>
        </select>
        <span style="font-size:11px;color:var(--muted);margin-left:auto;">DNA盖章·8层pipeline</span>
      </div>

      <div class="chat-messages" id="chatMessages">
        <div class="msg bot">
          <div class="msg-avatar">🐉</div>
          <div>
            <div class="msg-bubble">
              龍魂引擎就绪。<br>
              <span style="font-size:11px;color:var(--muted)">DNA: #龍芯⚡️2026-04-07-PORTAL-CHAT · 每句话是1 · 归一</span>
            </div>
            <div class="msg-meta">🟢 在线 · localhost:8000</div>
          </div>
        </div>
      </div>

      <div class="chat-input-area">
        <textarea class="chat-input" id="chatInput" placeholder="直接说，不用格式不用标签..."
          onkeydown="handleKey(event)"></textarea>
        <button class="send-btn" id="sendBtn" onclick="sendMessage()">发送 ↗</button>
      </div>
    </div>

    <!-- ── WebUI视图 ── -->
    <div class="view" id="view-webui">
      <div style="padding:10px 16px;background:var(--panel);border-bottom:1px solid var(--border);font-size:12px;color:var(--muted);display:flex;gap:10px;align-items:center;">
        <span>Open WebUI · localhost:8080</span>
        <a href="http://localhost:8080" target="_blank" style="color:var(--gold);text-decoration:none;font-size:11px;">↗ 新窗口打开</a>
      </div>
      <iframe src="http://localhost:8080" id="webuiFrame" style="flex:1;border:none;width:100%;background:var(--bg);"
        onerror="this.srcdoc='<div style=background:#07070f;color:#555;display:flex;height:100%;align-items:center;justify-content:center;font-family:monospace;font-size:13px;>8080 未启动 · python3 app.py 先跑起来</div>'">
      </iframe>
    </div>

    <!-- ── 九宫地图视图 ── -->
    <div class="view" id="view-map">
      <iframe src="/static/luoshu_map.html" class="map-iframe"></iframe>
    </div>

    <!-- ── 工具箱视图 ── -->
    <div class="view" id="view-tools">
      <div style="font-size:14px;color:var(--gold);margin-bottom:16px;letter-spacing:2px;">🔧 龍魂工具箱</div>
      <div class="tool-grid">
        <div class="tool-card" onclick="openTool('glyph')">
          <div class="ti">🐉</div>
          <div class="tn">CNSH字元设计器</div>
          <div class="td">画字·导出SVG</div>
        </div>
        <div class="tool-card" onclick="runScript('health')">
          <div class="ti">🏥</div>
          <div class="tn">系统自检</div>
          <div class="td">health_check.py</div>
        </div>
        <div class="tool-card" onclick="runScript('luoshu')">
          <div class="ti">☯</div>
          <div class="tn">洛书路由器</div>
          <div class="td">重新路由所有页面</div>
        </div>
        <div class="tool-card" onclick="runScript('font')">
          <div class="ti">🔤</div>
          <div class="tn">安装全套字体</div>
          <div class="td">install_fonts.sh</div>
        </div>
        <div class="tool-card" onclick="runScript('media')">
          <div class="ti">📁</div>
          <div class="tn">媒体归集</div>
          <div class="td">media_collect.sh</div>
        </div>
        <div class="tool-card" onclick="openNotion('audit')">
          <div class="ti">📋</div>
          <div class="tn">三色审计中心</div>
          <div class="td">Notion审计页</div>
        </div>
        <div class="tool-card" onclick="showDNA()">
          <div class="ti">🔐</div>
          <div class="tn">DNA签名查看</div>
          <div class="td">GPG + UID9622</div>
        </div>
        <div class="tool-card" onclick="openNotion('algo')">
          <div class="ti">🔢</div>
          <div class="tn">算法元数据库</div>
          <div class="td">9族算法查询</div>
        </div>
      </div>

      <div style="margin-top:20px;background:var(--panel);border:1px solid var(--border);border-radius:8px;padding:14px;">
        <div style="font-size:11px;color:var(--muted);margin-bottom:8px;">终端快捷指令</div>
        <div style="display:flex;flex-direction:column;gap:6px;" id="cmdList"></div>
      </div>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// ══ 九宫数据 ══
const PALACES = [
  {num:4,icon:'🔄',name:'巽·协同',color:'#7b5ea7'},
  {num:9,icon:'🌟',name:'离·元宇',color:'#e0d45a'},
  {num:2,icon:'🏗',name:'坤·架构',color:'#8B7355'},
  {num:3,icon:'⚡',name:'震·人格',color:'#4caf7d'},
  {num:5,icon:'💎',name:'中·核心',color:'#c8a84b'},
  {num:7,icon:'💬',name:'兑·记忆',color:'#e0a05a'},
  {num:8,icon:'🔢',name:'艮·算法',color:'#9a7aa0'},
  {num:1,icon:'🔧',name:'坎·技术',color:'#5a9ae0'},
  {num:6,icon:'👑',name:'乾·道法',color:'#e05a5a'},
];

// Notion页面ID
const NOTION = {
  main: 'd553c3d4',
  audit: 'b35faf46',
  runtime: '16422f72',
  algo: 'f80f0ea1',
};

// 终端指令列表
const CMDS = [
  {label:'系统自检', cmd:'python3 ~/longhun-system/bin/health_check.py'},
  {label:'启动引擎', cmd:'python3 ~/longhun-system/app.py'},
  {label:'安装字体', cmd:'bash ~/longhun-system/bin/install_fonts.sh'},
  {label:'洛书路由', cmd:'python3 ~/longhun-system/bin/luoshu_router.py'},
  {label:'媒体归集', cmd:'bash ~/longhun-system/bin/media_collect.sh'},
  {label:'字体构建', cmd:'python3 ~/longhun-system/CNSH引擎/cnsh_font_builder_v2_LU.py'},
];

// ══ 初始化 ══
function init() {
  // 九宫导航
  const nav = document.getElementById('luoshuNav');
  PALACES.forEach(p => {
    const cell = document.createElement('div');
    cell.className = 'luo-cell';
    cell.style.borderColor = p.color + '44';
    cell.innerHTML = `<div class="lnum" style="color:${p.color}">${p.icon}</div><div class="lname">${p.name.split('·')[1]}</div>`;
    cell.onclick = () => { switchView('map'); };
    cell.title = p.name;
    nav.appendChild(cell);
  });

  // 终端指令
  const cmdList = document.getElementById('cmdList');
  CMDS.forEach(c => {
    const row = document.createElement('div');
    row.style.cssText = 'display:flex;align-items:center;gap:8px;padding:6px 10px;background:var(--panel2);border-radius:5px;border:1px solid var(--border);cursor:pointer;';
    row.innerHTML = `
      <span style="font-size:11px;color:var(--muted);width:60px;flex-shrink:0">${c.label}</span>
      <code style="font-size:11px;color:var(--text);flex:1;font-family:monospace">${c.cmd}</code>
      <span style="font-size:10px;color:var(--muted)">复制</span>
    `;
    row.onclick = () => {
      navigator.clipboard.writeText(c.cmd).then(() => toast('已复制: ' + c.label));
    };
    cmdList.appendChild(row);
  });

  // 状态格
  renderStatusGrid();
  checkAllServers();
}

// ══ 服务器检测 ══
async function checkServer(port) {
  try {
    const resp = await fetch(`http://localhost:${port}/`, {
      method: 'GET', mode: 'no-cors', signal: AbortSignal.timeout(2000)
    });
    return true;
  } catch(e) {
    return false;
  }
}

async function checkAllServers() {
  const ports = [8000, 8080, 9622, 8765];
  for (const port of ports) {
    const el = document.getElementById(`srv-${port}`);
    try {
      await fetch(`http://localhost:${port}/`, {
        mode: 'no-cors', signal: AbortSignal.timeout(1500)
      });
      if (el) { el.classList.add('online'); el.classList.remove('offline'); }
      updateStatusGrid(port, true);
    } catch(e) {
      if (el) { el.classList.add('offline'); el.classList.remove('online'); }
      updateStatusGrid(port, false);
    }
  }
  document.getElementById('engine-status').textContent =
    document.getElementById('srv-8000')?.classList.contains('online') ? '🟢 在线' : '🔴 离线';
}

function renderStatusGrid() {
  document.querySelectorAll('.stat-item').forEach(el => {
    const port = el.dataset.port;
    const label = el.dataset.label;
    el.style.cssText = 'background:var(--panel2);border:1px solid var(--border);border-radius:8px;padding:10px 14px;display:flex;align-items:center;gap:8px;';
    el.innerHTML = `
      <div style="width:8px;height:8px;border-radius:50%;background:var(--muted);flex-shrink:0" id="dot-${port}"></div>
      <div>
        <div style="font-size:12px;color:var(--text)">:${port} · ${label}</div>
        <div style="font-size:10px;color:var(--muted)" id="status-${port}">检测中...</div>
      </div>
    `;
  });
}

function updateStatusGrid(port, online) {
  const dot = document.getElementById(`dot-${port}`);
  const status = document.getElementById(`status-${port}`);
  if (dot) dot.style.background = online ? 'var(--green)' : 'var(--muted)';
  if (status) status.textContent = online ? '🟢 在线' : '⚫ 离线';
}

// ══ 视图切换 ══
function switchView(name) {
  document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('view-' + name)?.classList.add('active');
  document.getElementById('tab-' + name)?.classList.add('active');
}

// ══ 对话引擎 ══
let isSending = false;

async function sendMessage() {
  if (isSending) return;
  const input = document.getElementById('chatInput');
  const msg = input.value.trim();
  if (!msg) return;

  const port = document.getElementById('engineSelect').value;
  addMessage('user', msg);
  input.value = '';
  isSending = true;
  document.getElementById('sendBtn').disabled = true;

  // 打字动画
  const typingEl = document.createElement('div');
  typingEl.className = 'msg bot';
  typingEl.innerHTML = `<div class="msg-avatar">🐉</div><div class="msg-bubble"><div class="typing"><span></span><span></span><span></span></div></div>`;
  document.getElementById('chatMessages').appendChild(typingEl);
  scrollChat();

  try {
    const resp = await fetch(`http://localhost:${port}/chat`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ message: msg, uid: 'UID9622' }),
      signal: AbortSignal.timeout(30000)
    });
    typingEl.remove();
    if (resp.ok) {
      const data = await resp.json();
      const reply = data.reply || data.response || data.message || JSON.stringify(data);
      addMessage('bot', reply, data.dna || '');
    } else {
      addMessage('bot', `引擎响应异常 HTTP ${resp.status}，检查 app.py 是否跑起来`);
    }
  } catch(e) {
    typingEl.remove();
    if (e.name === 'TimeoutError') {
      addMessage('bot', '超时了，引擎在处理中，等一下再发');
    } else {
      addMessage('bot', `连不上 localhost:${port}，先跑：\npython3 ~/longhun-system/app.py`);
    }
  }

  isSending = false;
  document.getElementById('sendBtn').disabled = false;
  input.focus();
}

function addMessage(role, text, dna = '') {
  const wrap = document.createElement('div');
  wrap.className = `msg ${role}`;
  const avatar = role === 'user' ? '🐉' : '🤖';
  const metaText = role === 'bot' ? `<span style="color:var(--green)">🟢 引擎回复</span>${dna ? ' · ' + dna.substring(0,30) + '...' : ''}` : '你';
  wrap.innerHTML = `
    <div class="msg-avatar">${role === 'user' ? '💎' : '🐉'}</div>
    <div>
      <div class="msg-bubble" style="white-space:pre-wrap">${text}</div>
      <div class="msg-meta">${metaText}</div>
    </div>
  `;
  document.getElementById('chatMessages').appendChild(wrap);
  scrollChat();
}

function scrollChat() {
  const c = document.getElementById('chatMessages');
  c.scrollTop = c.scrollHeight;
}

function handleKey(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
}

// ══ 工具 ══
function openTool(name) {
  if (name === 'glyph') {
    window.open('/static/cnsh_glyph_designer.html', '_blank');
  }
}

function openNotion(key) {
  const id = NOTION[key];
  if (id) window.open(`https://www.notion.so/${id}`, '_blank');
  else toast('Notion ID未配置');
}

function openWebUI() {
  switchView('webui');
}

function runScript(name) {
  const scripts = {
    health: 'python3 ~/longhun-system/bin/health_check.py',
    luoshu: 'python3 ~/longhun-system/bin/luoshu_router.py',
    font: 'bash ~/longhun-system/bin/install_fonts.sh',
    media: 'bash ~/longhun-system/bin/media_collect.sh',
  };
  const cmd = scripts[name];
  if (cmd) {
    navigator.clipboard.writeText(cmd).then(() => toast('复制到剪贴板 → 粘进终端跑'));
  }
}

function showDNA() {
  toast('GPG: A2D0092CEE2E5BA87035600924C3704A8CC26D5F · Apache 2.0 · 休想二开');
}

function toast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2800);
}

// ══ IPA人格矩阵：五大中心点击跳Notion ══
document.querySelectorAll('.ipa-center[data-notion]').forEach(el => {
  const id = el.dataset.notion;
  if (id) {
    el.onclick = () => window.open(`https://www.notion.so/${id.replace(/-/g,'')}`, '_blank');
  }
});

// ══ 三才流场：从8001拉取实时权重 ══
async function fetchSancai() {
  try {
    const r = await fetch('http://localhost:8001/sancai/weights', { signal: AbortSignal.timeout(2000) });
    if (r.ok) {
      const d = await r.json();
      document.getElementById('sc-tian').querySelector('.sc-val').textContent = d['天'] ?? '—';
      document.getElementById('sc-di').querySelector('.sc-val').textContent  = d['地'] ?? '—';
      document.getElementById('sc-ren').querySelector('.sc-val').textContent = d['人'] ?? '—';
      document.getElementById('sc-time').textContent = d['时辰'] ?? '';
    }
  } catch(e) {
    // 8001离线时显示本地计算
    const h = new Date().getHours();
    const tian = +(0.35 + 0.05 * (h>=6&&h<=12 ? 1 : h>=18&&h<=24 ? -1 : 0)).toFixed(2);
    const di   = +(0.35 - 0.03 * (h>=12&&h<=18 ? 1 : 0)).toFixed(2);
    const ren  = +(1 - tian - di).toFixed(2);
    document.getElementById('sc-tian').querySelector('.sc-val').textContent = tian;
    document.getElementById('sc-di').querySelector('.sc-val').textContent  = di;
    document.getElementById('sc-ren').querySelector('.sc-val').textContent = ren;
    document.getElementById('sc-time').textContent = `${h}时·本地`;
  }
}

// ══ 启动 ══
init();
fetchSancai();
// 每30秒自动检查一次服务状态，每5分钟更新三才
setInterval(checkAllServers, 30000);
setInterval(fetchSancai, 300000);
</script>
</body>
</html>
