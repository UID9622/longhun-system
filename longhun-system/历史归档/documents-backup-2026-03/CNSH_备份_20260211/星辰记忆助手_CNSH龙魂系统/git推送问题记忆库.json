{
  "记忆库": [
    {
      "DNA标签": "GIT_PUSH_403_GITEE_AUTH_FAILED",
      "问题分类": "Gitee推送认证失败",
      "时间戳": "2026-02-02T17:30:00+08:00",
      "故障现象": {
        "错误信息": "remote: [session-4a44cbba] The token username invalid",
        "HTTP状态码": "403 Forbidden",
        "失败命令": "git push gitee main --force",
        "仓库URL": "https://gitee.com/uid9622_admin/cnsh-editor-phb.git"
      },
      "根本原因": [
        "Gitee HTTPS推送需要在URL中包含用户名和token",
        "当前URL不包含认证信息",
        "macOS Keychain中可能没有保存Gitee凭证"
      ],
      "解决方案": {
        "方案A_快速解决": {
          "步骤": [
            "获取Gitee私人令牌（Personal Access Token）",
            "在仓库设置 > 私人令牌 > 生成新令牌",
            "权限勾选：projects (读写)",
            "使用带token的URL推送"
          ],
          "命令模板": [
            "git remote remove gitee",
            "git remote add gitee https://你的用户名:你的token@gitee.com/uid9622_admin/cnsh-editor-phb.git",
            "git push gitee main --force"
          ]
        },
        "方案B_SSH密钥": {
          "步骤": [
            "生成SSH密钥对（如果没有）：ssh-keygen -t ed25519 -C 'uid9622@petalmail.com'",
            "查看公钥：cat ~/.ssh/id_ed25519.pub",
            "在Gitee > 设置 > SSH公钥 中添加",
            "修改remote为SSH格式"
          ],
          "命令模板": [
            "git remote remove gitee",
            "git remote add gitee git@gitee.com:uid9622_admin/cnsh-editor-phb.git",
            "git push gitee main --force"
          ]
        },
        "方案C_凭证管理器": {
          "说明": "使用git-credential-osxkeychain存储凭证",
          "命令": [
            "git config --global credential.helper osxkeychain",
            "首次push时输入用户名和密码，之后自动记住"
          ]
        }
      },
      "预防措施": [
        "配置SSH密钥作为主要认证方式（一次配置，永久使用）",
        "在~/.gitconfig中配置credential helper",
        "将Gitee token保存到密码管理器",
        "定期检查token有效期"
      ],
      "快速诊断清单": [
        "1. 检查token是否过期",
        "2. 检查token权限范围",
        "3. 检查用户名拼写",
        "4. 检查仓库访问权限",
        "5. 尝试SSH方式"
      ],
      "相关DNA": [
        "GITHUB_PUSH_NETWORK_TIMEOUT",
        "GIT_CREDENTIAL_MANAGEMENT",
        "SSH_KEY_SETUP"
      ],
      "记忆强度": "永久",
      "触发关键词": [
        "gitee",
        "403",
        "token invalid",
        "push失败",
        "认证错误"
      ]
    }
  ]
