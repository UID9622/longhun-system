{
  "files.associations": {
    "*.cnsh": "python",
    "*.longhun": "javascript"
  },
  "editor.fontSize": 14,
  "editor.tabSize": 4,
  "editor.formatOnSave": true,
  "editor.wordWrap": "on",
  
  "[python]": {
    "editor.defaultFormatter": "ms-python.python",
    "editor.formatOnSave": true
  },
  
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  
  "cnsh.enableIntelliSense": true,
  "cnsh.enableAudit": true,
  "cnsh.enableDNATracing": true,
  "cnsh.enableDeduction": true,
  
  "cnsh.aiBackends": {
    "claude": {
      "enabled": true,
      "priority": 2
    },
    "deepseek": {
      "enabled": true,
      "priority": 3
    },
    "notion": {
      "enabled": true,
      "priority": 1
    }
  },
  
  "cnsh.security": {
    "auditLevel": "normal",
    "dnaTracing": true,
    "dataEncryption": true,
    "dataSovereignty": "china"
  },
  
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.fontSize": 13,
  
  "workbench.colorCustomizations": {
    "statusBar.background": "#1a1a2e",
    "statusBar.foreground": "#eee",
    "activityBar.background": "#16213e"
  },
  
  "editor.tokenColorCustomizations": {
    "comments": "#6a9955",
    "strings": "#ce9178"
  }
}
