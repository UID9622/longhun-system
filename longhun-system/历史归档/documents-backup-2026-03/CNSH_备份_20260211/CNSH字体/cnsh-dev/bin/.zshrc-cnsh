# ============================================================
# CNSH-EDITOR v0.1.1 终端配置
# 添加到 ~/.zshrc 的末尾
# ============================================================

# CNSH 路径
export CNSH_ROOT="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Desktop/cnsh-dev"
export PATH="$CNSH_ROOT/bin:$PATH"

# 主命令：一键进入开发环境
alias cnsh='cd "$CNSH_ROOT" && "$CNSH_ROOT/bin/cnsh"'

# 快捷命令
alias cnsh-inbox='cd "$CNSH_ROOT/vault/inbox" && nvim'
alias cnsh-db='sqlite3 "$CNSH_ROOT/db/cnsh_kb.db"'
alias cnsh-sync='"$CNSH_ROOT/sync/notion-sync.sh"'
alias cnsh-status='"$CNSH_ROOT/bin/cnsh" status'
alias cnsh-new='"$CNSH_ROOT/bin/cnsh" new'
alias cnsh-recent='"$CNSH_ROOT/bin/cnsh" recent'

# 自动补全（如果有 oh-my-zsh）
_cnsh_complete() {
    local -a commands
    commands=(
        'status:显示系统状态'
        'new:创建新笔记'
        'recent:列出最近笔记'
        'search:搜索笔记'
        'db:执行SQL查询'
        'help:显示帮助'
    )
    _describe 'command' commands
}
compdef _cnsh_complete cnsh 2>/dev/null || true

# 启动提示（可选）
# echo "🐉 CNSH-EDITOR v0.1.1 已加载 | 输入 'cnsh' 进入开发环境"
