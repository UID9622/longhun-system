# ============================================================
# 服务配置
# ============================================================

# 监听端口
SERVICE_PORT=8765

# 监听地址（0.0.0.0 = 所有接口，127.0.0.1 = 仅本地）
SERVICE_HOST=0.0.0.0

# 调试模式（True/False）
DEBUG_MODE=False

# ============================================================
# 模型配置
# ============================================================

# Ollama API地址
OLLAMA_BASE_URL=http://localhost:11434/v1

# 默认模型（qwen2.5:14b, llama3.1:8b, mistral:7b）
DEFAULT_MODEL=qwen2.5:14b

# 温度参数（0.0-2.0，越高越随机）
TEMPERATURE=0.7

# 最大token数
MAX_TOKENS=2000

# ============================================================
# 数据存储
# ============================================================

# 记忆数据库路径
MEMORY_DB_PATH=~/.longhun/memories.db

# 日志目录
LOG_DIR=~/.longhun/logs

# 备份目录
BACKUP_DIR=~/.longhun/backups

# ============================================================
# 安全配置
# ============================================================

# GPG指纹
GPG_FINGERPRINT=A2D0092CEE2E5BA87035600924C3704A8CC26D5F

# UID
USER_ID=9622

# ============================================================
# 功能开关
# ============================================================

# 启用记忆系统
ENABLE_MEMORY=True

# 启用L2审计
ENABLE_L2_AUDIT=True

# 启用DNA追溯
ENABLE_DNA_TRACE=True

# 启用文化守护
ENABLE_CULTURE_GUARD=True

# ============================================================
# 性能优化
# ============================================================

# 对话历史保留长度
MAX_HISTORY_LENGTH=10

# 缓存大小（条数）
CACHE_SIZE=100

# 自动清理过期数据（天数，0=不清理）
AUTO_CLEANUP_DAYS=0

# ============================================================
# Notion集成（可选）
# ============================================================

# Notion API Token（留空则禁用）
NOTION_API_TOKEN=

# Notion数据库ID
NOTION_DATABASE_ID=

# ============================================================
# 提示词定制
# ============================================================

# 自定义system prompt（留空使用默认）
CUSTOM_SYSTEM_PROMPT=

# ============================================================
# 高级功能
# ============================================================

# 启用向量化存储（需要额外依赖）
ENABLE_VECTOR_STORAGE=False

# 启用语音识别（需要Whisper）
ENABLE_VOICE_INPUT=False

# 启用图像识别（需要LLaVA）
ENABLE_IMAGE_INPUT=False

# ============================================================
# 日志配置
# ============================================================

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# 日志格式
LOG_FORMAT=[%(asctime)s] [%(levelname)s] %(message)s

# ============================================================
# 备份配置
# ============================================================

# 自动备份（True/False）
AUTO_BACKUP=False

# 备份频率（小时）
BACKUP_INTERVAL=24

# 保留备份数量
KEEP_BACKUPS=7

# ============================================================
# 说明
# ============================================================

# 修改此文件后需要重启服务
# 启动服务: ./start_longhun.sh
# 测试服务: ./test_longhun.sh

