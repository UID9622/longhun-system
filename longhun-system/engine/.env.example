# 龍魂9625引擎·环境变量模板
# 复制为 .env 再填: cp .env.example .env
# DNA: #龍芯⚡️2026-04-19-ENV-EXAMPLE-v1.0
#
# ⚠️  .env 永不进 git（已在 .gitignore 里）

# ──────────────── Notion ────────────────
# 从 notion.com/my-integrations 创建 Integration 拿 token
NOTION_TOKEN=
# 记错本数据库 ID（URL 里的 32 位字符串）
ERRATA_DB_ID=
NOTION_VERSION=2022-06-28

# ──────────────── 大脑 API ────────────────
# DeepSeek（中文主权·默认·便宜）
DEEPSEEK_API_KEY=

# Claude（深度推理·境外·脱敏后用）
ANTHROPIC_API_KEY=

# 本地 Ollama（完全离线·最高主权）
OLLAMA_MODEL=qwen2.5:7b
