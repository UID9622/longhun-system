#!/bin/zsh
# CNSH-EDITOR v0.1.1 终端入口
# 一键进入开发环境

# 颜色定义
CNSH_RED='\033[0;31m'
CNSH_GREEN='\033[0;32m'
CNSH_YELLOW='\033[1;33m'
CNSH_BLUE='\033[0;34m'
CNSH_CYAN='\033[0;36m'
CNSH_NC='\033[0m'

# 路径配置
CNSH_ROOT="$HOME/Library/Mobile Documents/com~apple~CloudDocs/Desktop/cnsh-dev"
CNSH_DB="$CNSH_ROOT/db/cnsh_kb.db"
CNSH_VAULT="$CNSH_ROOT/vault"

# 打印 banner
cnsh_banner() {
    echo -e "${CNSH_CYAN}"
    echo "╔════════════════════════════════════════════════════════════╗"
    echo "║  🐉 CNSH-EDITOR v0.1.1                                     ║"
    echo "║  龍魂体系 · 知识管理终端                                    ║"
    echo "╚════════════════════════════════════════════════════════════╝"
    echo -e "${CNSH_NC}"
}

# 显示状态
cnsh_status() {
    echo -e "${CNSH_BLUE}[系统状态]${CNSH_NC}"
    
    # 统计笔记数量
    local total=$(sqlite3 "$CNSH_DB" "SELECT COUNT(*) FROM notes;" 2>/dev/null || echo "0")
    local inbox=$(sqlite3 "$CNSH_DB" "SELECT COUNT(*) FROM notes WHERE status='inbox';" 2>/dev/null || echo "0")
    local wip=$(sqlite3 "$CNSH_DB" "SELECT COUNT(*) FROM notes WHERE status='wip';" 2>/dev/null || echo "0")
    
    echo "  📁 总笔记: $total | 📥 收件箱: $inbox | 🔨 进行中: $wip"
    echo ""
}

# 数据库查询工具
cnsh_db() {
    sqlite3 "$CNSH_DB" "$@"
}

# 列出最近笔记
cnsh_recent() {
    local limit=${1:-10}
    echo -e "${CNSH_YELLOW}最近 $limit 条笔记:${CNSH_NC}"
    sqlite3 "$CNSH_DB" <<EOF
.header on
.mode column
SELECT 
    substr(id, -4) as id_short,
    title,
    status,
    datetime(modified_at, 'localtime') as modified
FROM notes 
ORDER BY modified_at DESC 
LIMIT $limit;
EOF
}

# 创建新笔记
cnsh_new() {
    local title="${1:-新笔记}"
    local timestamp=$(date +%s)
    local dna="#ZHUGEXIN⚡️-CNSH-NOTE-$(printf "%04d" $(sqlite3 "$CNSH_DB" "SELECT COUNT(*) + 1 FROM notes;"))"
    local filename="$(date +%Y%m%d)-$(echo $title | tr ' ' '-').md"
    local filepath="inbox/$filename"
    
    # 创建文件
    cat > "$CNSH_VAULT/$filepath" <<EOF
---
id: $dna
title: $title
created: $(date '+%Y-%m-%d %H:%M:%S')
status: inbox
tags: []
---

# $title

EOF
    
    # 插入数据库
    sqlite3 "$CNSH_DB" "INSERT INTO notes (id, path, title, status) VALUES ('$dna', 'vault/$filepath', '$title', 'inbox');"
    
    echo -e "${CNSH_GREEN}✅ 创建笔记: $title${CNSH_NC}"
    echo -e "   DNA: $dna"
    echo -e "   路径: $filepath"
}

# 搜索笔记
cnsh_search() {
    local keyword="$1"
    echo -e "${CNSH_YELLOW}搜索: $keyword${CNSH_NC}"
    sqlite3 "$CNSH_DB" <<EOF
SELECT id, title, status FROM notes 
WHERE title LIKE '%$keyword%' OR path LIKE '%$keyword%'
ORDER BY modified_at DESC;
EOF
}

# 帮助信息
cnsh_help() {
    echo -e "${CNSH_CYAN}CNSH-EDITOR 命令指南${CNSH_NC}"
    echo ""
    echo "用法: cnsh [命令] [参数]"
    echo ""
    echo "命令:"
    echo "  (无参数)     进入 Neovim 编辑 inbox"
    echo "  status       显示系统状态"
    echo "  new <标题>   创建新笔记"
    echo "  recent [n]   列出最近 n 条笔记 (默认 10)"
    echo "  search <关键词> 搜索笔记"
    echo "  db <SQL>     执行 SQL 查询"
    echo "  help         显示此帮助"
    echo ""
    echo "示例:"
    echo "  cnsh new \"设计思路\""
    echo "  cnsh recent 5"
    echo "  cnsh search editor"
    echo "  cnsh db \"SELECT * FROM notes WHERE status='wip';\""
}

# 主逻辑
cnsh_main() {
    case "$1" in
        status)
            cnsh_banner
            cnsh_status
            ;;
        new)
            cnsh_new "$2"
            ;;
        recent)
            cnsh_recent "$2"
            ;;
        search)
            cnsh_search "$2"
            ;;
        db)
            shift
            cnsh_db "$@"
            ;;
        help|--help|-h)
            cnsh_help
            ;;
        *)
            # 默认进入 Neovim
            cnsh_banner
            cnsh_status
            cd "$CNSH_VAULT"
            if command -v nvim &> /dev/null; then
                nvim inbox/
            else
                vim inbox/
            fi
            ;;
    esac
}

# 执行
cnsh_main "$@"
