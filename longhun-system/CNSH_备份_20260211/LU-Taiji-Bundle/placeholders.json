{
  "_comment": " centralized placeholder management for security",
  "placeholders": {
    "NOTION_API_KEY": {
      "description": "Notion Integration Token",
      "required": true,
      "sensitive": true,
      "instructions": "从 https://www.notion.so/my-integrations 获取"
    },
    "NOTION_DATABASE_ID": {
      "description": "目标数据库 ID",
      "required": true,
      "sensitive": false,
      "instructions": "从 Notion 数据库 URL 中提取"
    },
    "CUSTOM_USER_NAME": {
      "description": "自定义用户名",
      "required": false,
      "sensitive": false,
      "default": "Lucky"
    },
    "DEBUG_MODE": {
      "description": "调试模式",
      "required": false,
      "sensitive": false,
      "default": "false"
    }
  },
  "config_template": {
    "api_key": "{{NOTION_API_KEY}}",
    "database_id": "{{NOTION_DATABASE_ID}}",
    "user_name": "{{CUSTOM_USER_NAME}}",
    "debug": "{{DEBUG_MODE}}"
  }
}
