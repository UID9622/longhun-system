    "@cloud/localcore": "1.1.37",
    "@cloud/toolkit-plugin-devtool": "1.0.10",
    "@grpc/grpc-js": "^1.9.15",
    "@grpc/reflection": "^1.0.4",
    "@lenml/tokenizer-deepseek_v3": "^3.4.2",
