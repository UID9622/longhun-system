{
  "name": "codearts-snap",
  "displayName": "CodeArts Agent",
  "description": "With CodeArts Agent, writing code feels like a finger snap.",
  "version": "26.2.0",
  "publisher": "huaweicloud",
  "icon": "assets/logo_opaque.png",
  "engines": {
    "vscode": "^1.69.0",
    "codearts": "^2.1.6"
  },
  "toolkitPlatformConfig": {
    "startWhitelistedVersion": "1.0.7"
  },
  "categories": [
    "AI",
		"Chat",
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "mcp",
    "agent",
    "Java",
    "Python",
    "C++",
    "Code Generation"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onLanguage"
  ],
  "repository": {
    "type": "git",
    "url": ""
  },
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "contributes": {
    "icons": {
      "logo-ready-light": {
        "description": "light login logo",
        "default": {
          "fontPath": "assets/snap/light/login.woff",
          "fontCharacter": "\\e900"
        }
      },
      "logo-connecting-light": {
        "description": "light connecting logo",
        "default": {
          "fontPath": "assets/snap/light/connecting.woff",
          "fontCharacter": "\\e900"
        }
      },
      "logo-logout-light": {
        "description": "light logout logo",
        "default": {
          "fontPath": "assets/snap/light/logout.woff",
          "fontCharacter": "\\e900"
        }
      },
       "logo-ready-dark": {
        "description": "dark login logo",
        "default": {
          "fontPath": "assets/snap/dark/login.woff",
          "fontCharacter": "\\e900"
        }
      },
      "logo-connecting-dark": {
        "description": "dark connecting logo",
        "default": {
          "fontPath": "assets/snap/dark/connecting.woff",
          "fontCharacter": "\\e900"
        }
      },
      "logo-logout-dark": {
        "description": "dark logout logo",
        "default": {
          "fontPath": "assets/snap/dark/logout.woff",
          "fontCharacter": "\\e900"
        }
      }
    },
    "colors": [
      {
        "id": "codebot.promptColor",
        "description": "prompt decoration color",
        "defaults": {
          "dark": "#666666",
          "light": "#999999",
          "highContrast": "#666666"
        }
      }
    ],
    "commands": [
      {
        "command": "codebot.regenerate",
        "title": "%codebot.regenerate.title%"
      },
      {
        "command": "codebot.Active",
        "title": "%codebot.active.title%"
      },
      {
        "command": "codebot.ActiveSingleLine",
        "title": "%codebot.ActiveSingleLine.title%"
      },
      {
        "command": "codebot.accpetInlineSuggestion",
        "title": "%codebot.accpetInlineSuggestion.title%"
      },
      {
        "command": "codebot.cancelCodeGenerate",
        "title": "%codebot.cancelCodeGenerate.title%"
      },
      {
        "command": "codebot.ut-generate",
        "title": "%codebot.ut-generate.title%",
        "enablement": "editorHasSelection"
      },
      {
        "command": "codebot.code-debug",
        "title": "%codebot.code-debug.title%",
        "enablement": "editorHasSelection"
      },
      {
        "command": "codebot.code-explain",
        "title": "%codebot.code-explain.title%",
        "enablement": "editorHasSelection"
      },
      {
        "command": "codebot.code-comment",
        "title": "%codebot.code-comment.title%",
        "enablement": "editorHasSelection"
      },
      {
        "command": "codebot.code-optimize",
        "title": "%codebot.code-optimize.title%",
        "enablement": "editorHasSelection"
      },
      {
        "command": "codebot.addChat",
        "title": "%codebot.addChat.title%"
      },
      {
        "command": "codebot.diff.review",
        "title": "%codebot.diff.review.title%",
        "icon": "$(logo-ready-dark)"
      },
      {
        "command": "codebot.openCurrentLogFile",
        "title": "%codebot.openLogFile.title%"
      },
      {
        "command": "codebot.commit.message",
        "title": "%codebot.commitMessage.generate%",
        "icon": "$(logo-ready-dark)"
      },
      {
        "command": "codebot.refreshWebview",
        "icon": "$(extensions-refresh)",
        "title": "%codebot.refreshWebview.title%"
      },
      {
        "command": "codebot.openWebviewInEditor",
        "icon":"$(go-to-editing-session)",
        "title": "%codebot.openWebviewInEditor.title%"
      },
      {
        "command": "codebot.openWebviewInNewWindow",
        "icon":"$(multiple-windows)",
        "title": "%codebot.openWebviewInNewWindow.title%"
      },
      {
        "command": "codebot.referenceExplorerFile",
        "title": "%codebot.referenceExplorerFile.title%"
      },
      {
        "command": "codebot.referenceExplorerFolder",
        "title": "%codebot.referenceExplorerFolder.title%"
      },
      {
        "command": "codebot.chat.Active",
        "title": "%codebot.switchMode.chat.title%",
        "icon": "$(arrow-swap)"
      },
      {
        "command": "codebot.openFeedback",
        "title": "%codebot.openFeedback%"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "codebot.diff.review",
          "group": "navigation",
          "when": "isInDiffEditor && !codeDiffReviewDisable"
        }
      ],
      "editor/context": [
        {
          "submenu": "codebot.action",
          "when": "resourceScheme != 'output'",
          "group": "navigation"
        },
        {
          "command": "codebot.addChat",
          "when": "editorHasSelection && resourceScheme != 'output'",
          "title": "%codebot.addChat.title%",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "submenu": "codebot.explorer.menu",
          "group": "1_modification@0"
        }
      ],
      "scm/title": [
        {
          "when": "scmProvider == git",
          "command": "codebot.commit.message",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "codebot.refreshWebview",
          "group": "navigation@1",
          "when": "view == codebot.view"
        },
        {
          "command": "codebot.openWebviewInEditor",
          "group": "navigation@3",
          "when": "view == codebot.view && !disableMultiWindow"
        },
        {
          "command": "codebot.openWebviewInNewWindow",
          "group": "navigation@4",
          "when": "view == codebot.view && !disableMultiWindow"
        }
      ],
      "codebot.action": [
        {
          "command": "codebot.code-explain",
          "group": "codebot@1",
          "when": "editorHasSelection",
          "title": "%codebot.code-explain.title%"
        },
        {
          "command": "codebot.code-comment",
          "group": "codebot@2",
          "when": "editorHasSelection",
          "title": "%codebot.code-comment.title%"
        },
        {
          "command": "codebot.code-debug",
          "group": "codebot@3",
          "when": "editorHasSelection",
          "title": "%codebot.code-debug.title%"
        },
        {
          "command": "codebot.code-optimize",
          "group": "codebot@4",
          "when": "editorHasSelection",
          "title": "%codebot.code-optimize.title%"
        },
        {
          "command": "codebot.ut-generate",
          "group": "codebot@5",
          "when": "editorHasSelection",
          "title": "%codebot.ut-generate.title%"
        }
      ],
      "codebot.explorer.menu": [
        {
          "command": "codebot.referenceExplorerFile",
          "when": "!explorerResourceIsFolder && resourceExtname !== '.png' && resourceExtname !== '.jpg' && resourceExtname !== '.jpeg'  && resourceExtname !== '.PNG' && resourceExtname !== '.JPG' && resourceExtname !== '.JPEG'",
          "title": "%codebot.referenceExplorerFile.title%"
        },
        {
          "command": "codebot.referenceExplorerFolder",
          "when": "explorerResourceIsFolder",
          "title": "%codebot.referenceExplorerFolder.title%"
        }
      ]
    },
    "submenus": [
      {
        "id": "codebot.action",
        "label": "%extension.name%"
      },
      {
        "id": "codebot.explorer.menu",
        "label": "%extension.name%"
      }
    ],
    "keybindings": [
      {
        "command": "codebot.Active",
        "key": "alt+c",
        "when": "editorTextFocus"
      },
      {
        "command": "codebot.ActiveSingleLine",
        "key": "alt+x",
        "when": "editorTextFocus"
      },
      {
        "command": "codebot.chat.Active",
        "key": "alt+u"
      },
      {
        "command": "codebot.regenerate",
        "key": "alt+r",
        "when": "editorTextFocus"
      },
      {
        "command": "codebot.accpetInlineSuggestion",
        "key": "tab",
        "when": "inlineSuggestionVisible && !editorTabMovesFocus"
      },
      {
        "command": "codebot.cancelCodeGenerate",
        "key": "escape",
        "when": "!editorTabMovesFocus && (inCodeGenerateProgress || inlineSuggestionVisible)"
      },
      {
        "command": "codebot.addChat",
        "key": "alt+i",
        "when": "editorTextFocus && editorHasSelection"
      }
    ],
    "viewsContainers": {
      "secondaryActivitybar": [
        {
          "id": "HuaweiCloud",
          "title": "%extension.name%",
          "icon": "assets/activeBarLogo-external.png"
        }
      ]
    },
    "views": {
      "HuaweiCloud": [
        {
          "type": "webview",
          "id": "codebot.view",
          "name": "%codebot%"
        }
      ]
    },
    "configuration": {
      "title": "%extension.name%",
      "properties": {
        "codebot.codeGeneration.mainSwitch": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%codebot.codeGeneration.mainSwitch.markdownDescription%",
          "order": 1
        },
        "codebot.codeGeneration.fragmentGenerationSwitch": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%codebot.codeGeneration.fragmentGenerationSwitch.markdownDescription%",
          "order": 2
        },
        "codebot.codeGeneration.completeFragmentGeneration": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%codebot.codeGeneration.completeFragmentGeneration.markdownDescription%",
          "order": 3
        },
        "codebot.codeGeneration.singleLineGenerationSwitch": {
          "type": "boolean",
          "default": true,
          "order": 4,
          "markdownDescription": "%codebot.codeGeneration.singleLineGenerationSwitch.markdownDescription%"
        },
        "codebot.codeGeneration.debounceDelay": {
          "type": "number",
          "default": 1000,
          "order": 5,
          "minimum": 75,
          "maximum": 1000,
          "markdownDescription": "%codebot.codeGeneration.autoTriggerTimeDelay.markdownDescription%"
        },
        "codebot.codeGeneration.doNotDisturb": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "hideShortcutKeyPrompt": {
              "type": "boolean",
              "description": "%codebot.codeGeneration.doNotDisturbMode.subitems.hideShortcutKeyPrompt%"
            }
          },
          "default": {
            "hideShortcutKeyPrompt": false
          },
          "order": 6
        },
        "codebot.configuration.logLevel": {
          "type": "string",
          "enum": [
            "Debug",
            "Info",
            "Warn",
            "Error"
          ],
          "default": "Info",
          "markdownDescription": "%codebot.logLevel.markdownDescription%",
          "order": 7
        },
        "codebot.configuration.fontSize": {
          "type": "number",
          "enum": [
            12,
            13,
            14,
            15,
            16
          ],
          "default": 13,
          "markdownDescription": "%codebot.configuration.fontSize.markdownDescription%",
          "order": 8
        },
        "codebot.configuration.enableSubTaskCodeLens": {
          "type": "object",
          "additionalProperties": false,
          "default": {
            "enableCodeExplain": true,
            "enableCodeComment": true,
            "enableCodeDebug": true,
            "enableCodeOptimize": true,
            "enableUtGenerate": true
          },
          "properties": {
            "enableCodeExplain": {
              "type": "boolean",
              "default": true,
              "description": "%configuration.subTaskCodeLens.enableCodeExplain.description%"
            },
            "enableCodeComment": {
              "type": "boolean",
              "default": true,
              "description": "%configuration.subTaskCodeLens.enableCodeComment.description%"
            },
            "enableCodeDebug": {
              "type": "boolean",
              "default": true,
              "description": "%configuration.subTaskCodeLens.enableCodeDebug.description%"
            },
            "enableCodeOptimize": {
              "type": "boolean",
              "default": true,
              "description": "%configuration.subTaskCodeLens.enableCodeOptimize.description%"
            },
            "enableUtGenerate": {
              "type": "boolean",
              "default": true,
              "description": "%configuration.subTaskCodeLens.enableUtGenerate.description%"
            }
          },
          "order": 9
        },
        "codebot.configuration.keepContext": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%codebot.configuration.keepContext.description%",
          "order": 10
        },
        "codebot.customLLmClient.registerCustomLLmClient": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%codebot.customLLmClient.registerCustomLLmClient.description%"
        },
        "codebot.configuration.language.prefer": {
          "type": "string",
          "default": "Auto",
          "enum": [
            "Auto",
            "中文",
            "English"
          ],
          "markdownDescription": "%codebot.configuration.language.prefer.markdownDescription%",
          "order": 11
        }
      }
    },
    "viewsWelcome": [
      {
        "view": "HuaweiCloud.settings",
        "contents": "%extension.welcome%"
      }
    ]
  },
  "scripts": {
    "build-vue": "cd CodeMate-WebView && npm i && npm run build-prod && cd .. && node script/prepareVueResource.js",
    "prepare": "npx rimraf out && npm run esbuild-base:production && npm run copy-assets && npm run copy-localcore-wasm && npm run copy-localcore-gitignore",
    "esbuild-base:watch": "node esbuild.js --watch",
    "esbuild-base:production": "node esbuild.js --production",
    "copy-assets": "node copyAssets.js",
    "copy-localcore-wasm": "copyfiles -f ./node_modules/@cloud/localcore/localcore/tools/**.wasm out/tools",
    "copy-localcore-gitignore": "copyfiles -f ./node_modules/@cloud/localcore/localcore/tools/gitignore/* out/tools/gitignore",
    "build": "npm run copy-assets && npm run copy-localcore-wasm && npm run copy-localcore-gitignore",
    "watch": "npm run esbuild-base:watch",
    "fmt": "prettier --write \"src/**/*.ts\"&& npm run test -- --fix",
    "test": "eslint src --ext ts && tsc --noEmit",
    "package:codearts": "cap package -p",
    "build-webview": "cd CodeMate-WebView && npm i -f && npm run build-vscode-vue && copyfiles --all ./dist/**/* ../ && cd ..",
    "package:vscode": "vsce package",
    "package": "npm run build:webview && npm run check-types && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src --ext ts",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "install:cline-webview": "cd cline/webview-ui && npm install && cd ../..",
    "start:cline-webview": "cd cline/webview-ui && npm run start && cd ../..",
    "build:cline-webview": "cd cline/webview-ui && npm run build && cd ../..",
    "dev:cline-webview": "cd cline/webview-ui && npm run dev && cd ../..",
    "prepare-env": "node script/prepareEnv.js"
  },
  "dependencies": {
