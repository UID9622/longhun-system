{
  "manifest_version": 3,
  "name": "☰☰ 龍魂 ☷ · UID9622",
  "version": "1.0.0",
  "description": "龍魂系统浏览器扩展 · 开发者信息栏 + GitHub增强 + Notion导航 · 诸葛鑫（UID9622）",
  "author": "诸葛鑫（UID9622）",
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "龍魂系统 · UID9622"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_devbar.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://github.com/*"],
      "js": ["content_github.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.notion.so/*"],
      "js": ["content_notion.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [],
  "host_permissions": []
}
