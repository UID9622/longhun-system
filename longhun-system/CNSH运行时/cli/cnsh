def cmd_new(name: str):
    """生成新程序模板"""
    filename = name if name.endswith(".cnsh") else f"{name}.cnsh"
    filepath = Path(filename)

    if filepath.exists():
        print(_yellow(f"文件已存在：{filepath}"))
        ans = input("是否覆盖？(y/N) ").strip().lower()
        if ans != 'y':
            print("已取消。")
            return

    today = datetime.now().strftime("%Y-%m-%d")
    content = TEMPLATE.format(name=name, date=today)
    filepath.write_text(content, encoding="utf-8")

    print(_green(f"✅ 已创建：{filepath}"))
    print(f"  运行方式：cnsh run {filepath}")

