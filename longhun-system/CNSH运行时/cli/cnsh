def main():
    args = sys.argv[1:]

    if not args:
        print(BANNER)
        print(HELP_TEXT)
        return

    cmd = args[0]
    cmd = ALIASES.get(cmd, cmd)  # 中文别名转英文

    if cmd in ("version", "--version", "-v"):
        print(BANNER)
        return

    if cmd in ("help", "--help", "-h"):
        print(BANNER)
        print(HELP_TEXT)
        return

    if cmd == "compile":
        if len(args) < 2:
            print(_red("错误：请指定 .cnsh 文件"))
            print("用法：cnsh compile <file.cnsh>")
            sys.exit(1)
        cmd_compile(args[1])
        return

    if cmd == "run":
        if len(args) < 2:
            print(_red("错误：请指定 .cnsh 文件"))
            print("用法：cnsh run <file.cnsh>")
            sys.exit(1)
        cmd_run(args[1])
        return

    if cmd == "build":
        if len(args) < 2:
            print(_red("错误：请指定目录"))
            print("用法：cnsh build <目录/>")
            sys.exit(1)
        cmd_build(args[1])
        return

    if cmd == "check":
        if len(args) < 2:
            print(_red("错误：请指定 .cnsh 文件"))
            print("用法：cnsh check <file.cnsh>")
            sys.exit(1)
        cmd_check(args[1])
        return

    if cmd == "new":
        if len(args) < 2:
            print(_red("错误：请指定程序名"))
            print("用法：cnsh new <程序名>")
            sys.exit(1)
        cmd_new(args[1])
        return

    print(_red(f"未知命令：{cmd}"))
    print("运行 cnsh help 查看所有命令。")
    sys.exit(1)


if __name__ == "__main__":
    main()
