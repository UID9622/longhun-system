def _check_compiler():
    if not _COMPILER.exists():
        print(_red(f"错误：找不到编译器 {_COMPILER}"))
        print("请确认 cnsh-runtime 目录结构完整。")
        sys.exit(1)

def _check_gcc():
    if not shutil.which("gcc"):
        print(_red("错误：系统中找不到 gcc，请先安装："))
        print("  macOS:  xcode-select --install")
        print("  Linux:  sudo apt install gcc")
        sys.exit(1)

def _dna_stamp():
