    return f"#龍芯⚡️{today}-CNSH-CLI-v1.0"

# ─────────────────────────────────────────────────────
# 三色审计（独立于编译器，快速版）
# ─────────────────────────────────────────────────────

import re

_RED_PATTERNS    = [r'暴力|血腥|杀人', r'诈骗|贩毒|恐怖', r'种族歧视|性别歧视']
_YELLOW_PATTERNS = [r'政治敏感', r'\d{15,18}']

def _quick_audit(source: str) -> tuple[str, str]:
    """返回 (颜色, 原因)"""
    for pat in _RED_PATTERNS:
        if re.search(pat, source):
            return "red", re.search(pat, source).group()
    for pat in _YELLOW_PATTERNS:
        if re.search(pat, source):
            return "yellow", re.search(pat, source).group()
    return "green", "内容安全"

# ─────────────────────────────────────────────────────
# compile 命令
# ─────────────────────────────────────────────────────

def cmd_compile(source_path: str) -> Path | None:
    """编译 .cnsh 文件，返回生成的 .c 文件路径（失败返回 None）"""
    _check_compiler()
    src = Path(source_path)

    if not src.exists():
        print(_red(f"错误：文件不存在 → {src}"))
        return None
    if src.suffix != ".cnsh":
        print(_red(f"错误：不是 .cnsh 文件 → {src}"))
        return None

    # 读源码
    source = src.read_text(encoding="utf-8")

    # 快速三色审计
    color, reason = _quick_audit(source)
    if color == "red":
        print(_red(f"🔴 三色审计阻断：{reason}"))
        print("   编译终止。")
        return None
    elif color == "yellow":
        print(_yellow(f"🟡 三色审计警告：{reason}，请注意内容"))
    else:
        print(_green("🟢 三色审计通过"))

    # 调用编译器（先 flush 确保审计消息已输出）
    sys.stdout.flush()
    result = subprocess.run(
        [sys.executable, str(_COMPILER), str(src)],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        if result.stderr:
            print(_red(result.stderr), end="")
        if result.stdout:
            print(result.stdout, end="")
        return None

    c_file = src.with_suffix(".c")
    if not c_file.exists():
        print(_red("错误：编译器未生成 .c 文件"))
        return None

    # 注入标准库
    try:
        from stdlib_injector import inject_stdlib
        c_code = c_file.read_text(encoding="utf-8")
        c_code = inject_stdlib(c_code)
        c_file.write_text(c_code, encoding="utf-8")
    except ImportError:
        pass  # 没有 stdlib_injector 也能继续

    print(_green(f"✅ 编译成功 → {c_file}"))
    return c_file

# ─────────────────────────────────────────────────────
# run 命令
# ─────────────────────────────────────────────────────

def cmd_run(source_path: str):
    """编译 + 用 gcc 构建 + 运行"""
    _check_gcc()

    src      = Path(source_path)
    c_file   = cmd_compile(source_path)
    if not c_file:
        sys.exit(1)

    exe_file = src.with_suffix("")

    # gcc 编译
    print(_cyan(f"⚙️  gcc 编译中 → {exe_file}"))
    gcc_result = subprocess.run(
        ["gcc", str(c_file), "-o", str(exe_file), "-lm"],
        capture_output=True, text=True
    )
    if gcc_result.returncode != 0:
        print(_red("❌ gcc 编译失败："))
        print(gcc_result.stderr)
        sys.exit(1)

    print(_green(f"✅ 构建成功 → {exe_file}"))
    print(_cyan("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"))
    print(_bold("🚀 运行输出："))
    print(_cyan("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"))
    sys.stdout.flush()

    # 运行（继承 stdout，实时输出）
    run_result = subprocess.run([str(exe_file)])
    sys.stdout.flush()
    print(_cyan("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"))
    print(f"DNA追溯：{_dna_stamp()}")

    sys.exit(run_result.returncode)

# ─────────────────────────────────────────────────────
# build 命令
# ─────────────────────────────────────────────────────

def cmd_build(dir_path: str):
    """批量编译目录下所有 .cnsh 文件"""
    d = Path(dir_path)
    if not d.is_dir():
        print(_red(f"错误：不是目录 → {d}"))
        sys.exit(1)

    files = list(d.glob("**/*.cnsh"))
    if not files:
        print(_yellow(f"目录中没有 .cnsh 文件：{d}"))
        return

    ok, fail = 0, 0
    for f in files:
        print(f"\n{_bold(f'→ 编译 {f.name}')}")
        c_file = cmd_compile(str(f))
        if c_file:
            ok += 1
        else:
            fail += 1

    print(f"\n{_cyan('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━')}")
    print(f"构建结果：{_green(f'{ok} 成功')}  {_red(f'{fail} 失败') if fail else ''}")
    if fail:
        sys.exit(1)

# ─────────────────────────────────────────────────────
# check 命令
# ─────────────────────────────────────────────────────

def cmd_check(source_path: str):
    """只做三色审计，不编译"""
    src = Path(source_path)
    if not src.exists():
        print(_red(f"错误：文件不存在 → {src}"))
        sys.exit(1)

    source = src.read_text(encoding="utf-8")
    color, reason = _quick_audit(source)

    print(f"\n三色审计报告 → {src.name}")
    print(_cyan("━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"))

    lines = source.split('\n')
    print(f"  行数：{len(lines)}")
    print(f"  字符：{len(source)}")

    if color == "red":
        print(_red(f"\n🔴 结论：不通过"))
        print(f"  原因：{reason}")
        sys.exit(1)
    elif color == "yellow":
        print(_yellow(f"\n🟡 结论：警告"))
        print(f"  原因：{reason}")
    else:
        print(_green(f"\n🟢 结论：通过"))
        print(f"  内容安全，可以编译")

