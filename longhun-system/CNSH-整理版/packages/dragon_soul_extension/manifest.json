{
  "manifest_version": 3,
  "name": "🐉 龙魂·思维主权守护者",
  "version": "1.0.0",
  "description": "自动净化输入，熔断风险内容，保障思维主权完整性",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "core/purifier.js",
        "core/dna-validator.js",
        "core/memory-compressor.js",
        "core/dna-generator.js",
        "core/taiji-extractor.js",
        "core/storage-manager.js",
        "core/memory-restorer.js",
        "core/asset-scanner.js",
        "content/content-script.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icons/icon-16.png",
      "48": "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    }
  },
  "web_accessible_resources": [
    {
      "resources": ["wasm/dragon_soul.wasm"],
      "matches": ["<all_urls>"]
    }
  ],
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
